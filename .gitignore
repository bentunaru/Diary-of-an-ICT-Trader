# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Screenshots temporaires
*.png
!favicon.png
!apple-touch-icon.png
!plans/*.png
!plans/**/*.png
# …sauf le dossier de travail (crops/screenshots intermédiaires) : conservé sur disque, non versionné.
plans/.trash_tmp/
*.jpg
*.jpeg
*.gif
*.bmp
*.tiff

# Sierra Chart exports (données brutes, non versionnées)…
*.txt
TradeStatisticsForCharts*.txt
# …SAUF les fills persistés par le pipeline : imports/ est la mémoire durable
# des sources (Sierra + TradingView) qui rend le journal régénérable à vie.
!imports/**/*.txt
!imports/**/*.csv

# PDFs générés (reproductibles depuis le dashboard)
*.pdf

# Boîte de dépôt locale (Ben y dépose exports Sierra/TradingView + screenshots en vrac,
# Claude trie vers imports/ et plans/YYYY-MM-DD/) — jamais versionnée telle quelle.
/inbox/*
!/inbox/.gitkeep

# Fichiers temporaires
*.tmp
*.bak
*~

# Node / Python si utilisés localement
node_modules/
__pycache__/
*.pyc
.env
